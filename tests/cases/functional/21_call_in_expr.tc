int inc(int x) {
    return x + 1;
}

int mul(int x, int y) {
    return x * y;
}

int main() {
    int a = 3;
    int b = 4;
    int r = inc(a) + mul(a, b) * inc(b) - mul(inc(a), inc(b));
    int s = 0;
    int i = 0;
    while (i < 6) {
        s = s + mul(i, inc(i)) - inc(a);
        i = i + 1;
    }
    if (r + s < 0) {
        return 0 - (r + s);
    }
    return (r + s) % 256;
}
