int classify(int n) {
    if (n < 0) {
        return -1;
    }
    if (n == 0) {
        return 0;
    }
    if (n < 10) {
        return 1;
    }
    if (n < 100) {
        return 2;
    }
    return 3;
}

int main() {
    return classify(-5) + classify(0) + classify(5)
         + classify(50) + classify(500);
}
