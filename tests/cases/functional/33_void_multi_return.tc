int result = 0;

void check(int x) {
    if (x <= 0) {
        return;
    }
    if (x == 1) {
        result = result + 1;
        return;
    }
    if (x == 2) {
        result = result + 2;
        return;
    }
    result = result + x;
}

int main() {
    check(0);
    check(1);
    check(2);
    check(5);
    return result;
}
