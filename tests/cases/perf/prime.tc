int isPrime(int n) {
    if (n < 2) { return 0; }
    int i = 2;
    while (i * i <= n) {
        if (n % i == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

int main() {
    int count = 0;
    int r = 0;
    while (r < 4000) {
        int k = 0;
        while (k < 4000) {
            if (isPrime(k)) { count = count + 1; }
            k = k + 1;
        }
        r = r + 1;
    }
    return count % 256;
}
